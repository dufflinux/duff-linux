do_build() {
	cargo build --release
}

do_install() {
	sed -i '3i conky -c ~/.conkyrc1 &' etc/xdg/pwm/startup.sh
	vmkdir /usr/bin
	vmkdir /usr/share/xsessions
	vmkdir /etc/xdg/pwm
	vcopy target/release/pwm /usr/bin/
	vcopy pwm.desktop /usr/share/xsessions/
	vcopy etc/xdg/pwm/'*' /etc/xdg/pwm/
}
